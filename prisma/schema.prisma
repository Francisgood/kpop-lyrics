datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Label {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  country     String?
  foundedYear Int?
  bio         String?
  website     String?
  logoUrl     String?
  artists     Artist[]
  createdAt   DateTime @default(now())
}

model Artist {
  id          String            @id @default(cuid())
  slug        String            @unique
  type        String
  stageName   String
  realName    String?
  debutYear   Int?
  bio         String?
  imageUrl    String?
  labelId     String?
  label       Label?            @relation(fields: [labelId], references: [id])
  memberships GroupMembership[] @relation("MemberOf")
  groupOf     GroupMembership[] @relation("GroupMembers")
  songs       SongCredit[]
  albums      Album[]
  news        ArtistNews[]
  cities      ArtistCity[]
  cityEvents  CityEvent[]
  createdAt   DateTime          @default(now())

  @@index([type])
  @@index([labelId])
}

model ArtistNews {
  id          String    @id @default(cuid())
  artistId    String
  artist      Artist    @relation(fields: [artistId], references: [id])
  headline    String
  body        String
  source      String?
  sourceUrl   String?
  category    String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([artistId])
  @@index([publishedAt])
  @@index([category])
}

model GroupMembership {
  id        String  @id @default(cuid())
  groupId   String
  memberId  String
  role      String?
  position  Int     @default(0)
  group     Artist  @relation("GroupMembers", fields: [groupId], references: [id])
  member    Artist  @relation("MemberOf", fields: [memberId], references: [id])

  @@index([groupId])
  @@index([memberId])
}

model Album {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id])
  releaseYear Int?
  coverArt    String?
  type        String
  songs       Song[]
  createdAt   DateTime @default(now())

  @@index([artistId])
  @@index([releaseYear])
}

model Song {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  albumId         String?
  album           Album?            @relation(fields: [albumId], references: [id])
  releaseYear     Int?
  coverArt        String?
  lyricsKo        String?
  lyricsEn        String?
  lyricsRomanized String?
  viewCount       Int               @default(0)
  credits         SongCredit[]
  annotations     LyricAnnotation[]
  cityCharts      SongCity[]
  createdAt       DateTime          @default(now())

  @@index([albumId])
  @@index([viewCount])
  @@index([releaseYear])
}

model SongCredit {
  id       String @id @default(cuid())
  songId   String
  artistId String
  role     String
  artist   Artist @relation(fields: [artistId], references: [id])
  song     Song   @relation(fields: [songId], references: [id])

  @@index([songId])
  @@index([artistId])
  @@index([role])
}

model LyricAnnotation {
  id        String              @id @default(cuid())
  songId    String
  song      Song                @relation(fields: [songId], references: [id])
  termId    String?
  term      CodedTerm?          @relation(fields: [termId], references: [id])
  userId    String?
  user      User?               @relation(fields: [userId], references: [id])
  lineIndex Int
  word      String
  note      String
  createdAt DateTime            @default(now())
  votes     AnnotationVote[]
  comments  AnnotationComment[]

  @@index([songId])
  @@index([termId])
  @@index([userId])
}

model AnnotationVote {
  id           String          @id @default(cuid())
  annotationId String
  annotation   LyricAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  value        Int             // 1 = upvote, -1 = downvote
  createdAt    DateTime        @default(now())

  @@unique([annotationId, userId])
  @@index([annotationId])
  @@index([userId])
}

model AnnotationComment {
  id           String          @id @default(cuid())
  annotationId String
  annotation   LyricAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  body         String
  createdAt    DateTime        @default(now())

  @@index([annotationId])
  @@index([userId])
}

model CodedTerm {
  id          String            @id @default(cuid())
  slug        String            @unique
  term        String
  definitions TermDefinition[]
  annotations LyricAnnotation[]
  signals     ContentSignal[]   @relation("TermSignals")
  createdAt   DateTime          @default(now())
}

model TermDefinition {
  id        String    @id @default(cuid())
  termId    String
  term      CodedTerm @relation(fields: [termId], references: [id])
  body      String
  example   String?
  votesUp   Int       @default(0)
  votesDown Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([termId])
}

// ── Auth & Community ──────────────────────────────────────────────────────────

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  passwordHash    String
  emailVerified   Boolean         @default(false)
  role            String          @default("user") // "user" | "editor" | "moderator" | "admin"
  is_owner        Boolean         @default(false)
  // Daebak Rewards progressive profile
  rewardsEnrolled Boolean         @default(false)
  phone           String?
  zipCode         String?
  mailingAddress  String?
  webPushEnabled  Boolean         @default(false)
  createdAt       DateTime        @default(now())
  sessions        Session[]
  favorites       Favorite[]
  suggestedEdits  SuggestedEdit[] @relation("EditorEdits")
  reviewedEdits   SuggestedEdit[] @relation("ReviewedEdits")
  comments            Comment[]
  auditLogs           AuditLog[]
  lyricAnnotations    LyricAnnotation[]
  annotationVotes     AnnotationVote[]
  annotationComments  AnnotationComment[]
  pointEvents         PointEvent[]
  kimchiRatings       KimchiRating[]
}

model PointEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  // "signup_bonus" | "comment" | "annotation" | "edit_approved" | "annotation_upvoted"
  type      String
  points    Int
  reason    String
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, type])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String   // "song" | "artist" | "album" | "term"
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType, entityId])
}

model SuggestedEdit {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation("EditorEdits", fields: [userId], references: [id])
  entityType     String    // "song" | "artist" | "album" | "term" | "annotation"
  entityId       String
  field          String    // which field is being edited
  currentVal     String?
  suggestedVal   String
  reason         String?
  status         String    @default("pending") // "pending" | "approved" | "rejected" | "reverted"
  reviewedById   String?
  reviewedBy     User?     @relation("ReviewedEdits", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([status])
  @@index([entityType, entityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // "approve" | "reject" | "revert" | "direct_edit"
  entityType String
  entityId   String
  editId     String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([editId])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String   // "song" | "artist" | "album" | "term" | "news"
  entityId   String
  body       String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

// ── Cities ────────────────────────────────────────────────────────────────────

model City {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  country     String
  flag        String?
  timezone    String?
  currency    String?
  color       String?
  description String?
  // JSON blob for supplementary static data: hotels, communities, kpopSpots
  metadata    String?
  artists     ArtistCity[]
  events      CityEvent[]
  songs       SongCity[]
  createdAt   DateTime     @default(now())
}

model ArtistCity {
  id       String @id @default(cuid())
  artistId String
  cityId   String
  // "based-in" | "popular-in" | "touring" | "hometown"
  type     String @default("popular-in")
  artist   Artist @relation(fields: [artistId], references: [id])
  city     City   @relation(fields: [cityId], references: [id])

  @@unique([artistId, cityId, type])
  @@index([cityId])
  @@index([artistId])
}

model CityEvent {
  id        String   @id @default(cuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  artistId  String?
  artist    Artist?  @relation(fields: [artistId], references: [id])
  title     String
  venue     String?
  // Flexible date string: "2025-08" or "Monthly" or "Year-round"
  eventDate String?
  ticketUrl String?
  // "concert" | "meetup" | "festival" | "fan-event"
  type      String   @default("concert")
  createdAt DateTime @default(now())

  @@index([cityId])
  @@index([type])
}

model SongCity {
  id     String @id @default(cuid())
  songId String
  cityId String
  rank   Int    @default(0)
  song   Song   @relation(fields: [songId], references: [id])
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([songId, cityId])
  @@index([cityId, rank])
}

// ── Trending & Signals ────────────────────────────────────────────────────────

model TrendingCache {
  id         String   @id @default(cuid())
  // "song" | "artist" | "term" | "city" | "collab"
  entityType String
  entityId   String
  score      Float    @default(0)
  // "daily" | "weekly" | "monthly"
  period     String   @default("daily")
  computedAt DateTime @default(now())

  @@unique([entityType, entityId, period])
  @@index([entityType, period, score])
}

// ── Kimchi Ratings ────────────────────────────────────────────────────────────

model KimchiRating {
  id         String   @id @default(cuid())
  entityType String   // "song" | "artist"
  entityId   String
  userId     String
  rating     Int      // 1–5
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, userId])
  @@index([entityType, entityId])
  @@index([userId])
}

// ── Sweepstakes ────────────────────────────────────────────────────────────────

model SweepstakesEntry {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  phone         String
  dateOfBirth   DateTime
  streetAddress String
  email         String   @unique
  gender        String
  newsletter    Boolean  @default(false)
  referralCode  String   @unique
  referredBy    String?
  referralCount Int      @default(0)
  totalEntries  Int      @default(1)
  createdAt     DateTime @default(now())

  @@index([referralCode])
  @@index([email])
}

// ── Search Analytics ─────────────────────────────────────────────────────────

model SearchMiss {
  id        String   @id @default(cuid())
  query     String
  // ERROR_SEARCH_NO_RESULTS
  errorCode String   @default("ERROR_SEARCH_NO_RESULTS")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

model ContentSignal {
  id          String    @id @default(cuid())
  // "song" | "artist" | "album" | "term" | "city" | "collab"
  entityType  String
  entityId    String
  // optional FK to CodedTerm if the signal is about a specific term
  termId      String?
  term        CodedTerm? @relation("TermSignals", fields: [termId], references: [id])
  headline    String
  body        String
  source      String?
  sourceUrl   String?
  // "collab" | "chart" | "release" | "tour" | "community" | "trending"
  category    String
  publishedAt DateTime?
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([category])
  @@index([publishedAt])
}
