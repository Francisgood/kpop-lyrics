{
  "name": "kpop-lyrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3007",
    "build": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed && next build",
    "start": "next start",
    "lint": "next lint",
    "giveaway:prepare": "node scripts/giveaway/prepare-manifest.mjs",
    "giveaway:finalize": "node scripts/giveaway/finalize-draw.mjs",
    "giveaway:verify": "node scripts/giveaway/verify-draw.mjs",
    "giveaway:chainlink:build": "forge build",
    "giveaway:chainlink:test": "forge test --no-match-path 'chainlink/test/*Fork*' -vvv",
    "giveaway:chainlink:test:fork": "forge test --match-path 'chainlink/test/*Fork*' -vvv",
    "giveaway:chainlink:draw": "node scripts/giveaway/chainlink/run-draw.mjs",
    "test:giveaway": "node --test scripts/giveaway/*.test.mjs scripts/giveaway/chainlink/*.test.mjs"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "@vercel/otel": "^2.1.3",
    "d3": "^7.9.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
